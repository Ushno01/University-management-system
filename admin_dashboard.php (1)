<?php
session_start();
include 'db.php';

if (!isset($_SESSION['admin'])) {
    header("Location: admin_login.php");
    exit();
}

$msg = "";

// Add Student
if (isset($_POST['add_student'])) {
    $sid    = trim($_POST['student_id']);
    $name   = trim($_POST['name']);
    $email  = trim($_POST['email']);
    $course = trim($_POST['course']);
    $result = trim($_POST['result']);
    $pass   = MD5(trim($_POST['password']));

    $check = mysqli_query($conn, "SELECT id FROM students WHERE student_id='$sid'");
    if (mysqli_num_rows($check) > 0) {
        $msg = "<p class='error'>Student ID already exists!</p>";
    } else {
        mysqli_query($conn, "INSERT INTO students (student_id, name, email, password, course, result)
                             VALUES ('$sid','$name','$email','$pass','$course','$result')");
        $msg = "<p class='success'>Student added successfully!</p>";
    }
}

// Update Student
if (isset($_POST['update_student'])) {
    $id     = $_POST['id'];
    $sid    = trim($_POST['student_id']);
    $name   = trim($_POST['name']);
    $email  = trim($_POST['email']);
    $course = trim($_POST['course']);
    $result = trim($_POST['result']);

    mysqli_query($conn, "UPDATE students SET student_id='$sid', name='$name', email='$email',
                         course='$course', result='$result' WHERE id='$id'");
    $msg = "<p class='success'>Student updated successfully!</p>";
}

// Delete Student
if (isset($_GET['delete'])) {
    $del_id = intval($_GET['delete']);
    mysqli_query($conn, "DELETE FROM students WHERE id='$del_id'");
    $msg = "<p class='success'>Student deleted.</p>";
}

// Fetch edit student
$edit_student = null;
if (isset($_GET['edit'])) {
    $eid = intval($_GET['edit']);
    $er  = mysqli_query($conn, "SELECT * FROM students WHERE id='$eid'");
    $edit_student = mysqli_fetch_assoc($er);
}

// All students
$all = mysqli_query($conn, "SELECT * FROM students ORDER BY id DESC");
?>
